<mxfile host="app.diagrams.net" agent="Cursor">
  <diagram id="psych-arch-01" name="Agent Psychologist Architecture">
    <mxGraphModel dx="8350" dy="2635" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="3200" pageHeight="2200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=22;fontStyle=1;" value="Архитектура ИИ-психолога&amp;nbsp;" vertex="1">
          <mxGeometry height="70" width="2635" x="242.5" y="160" as="geometry" />
        </mxCell>
        <mxCell id="orchestrator" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=15;align=left;verticalAlign=top;spacing=8;" value="&lt;b&gt;Вход и orchestration&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;Telegram handlers&lt;/b&gt;&lt;br&gt;- /start&lt;br&gt;- обычное сообщение&lt;br&gt;- /summary, /anket, /reset&lt;br&gt;&lt;br&gt;&lt;b&gt;DialogueService&lt;/b&gt;&lt;br&gt;- start_session()&lt;br&gt;- process_message()&lt;br&gt;- create_session_silent()&lt;br&gt;&lt;br&gt;&lt;b&gt;SessionState&lt;/b&gt;&lt;br&gt;Входы: profile + therapist prefs + clinical card + session + intake_state&lt;br&gt;Выход: runtime-contract для агентов" vertex="1">
          <mxGeometry height="420" width="540" x="-850" y="372" as="geometry" />
        </mxCell>
        <mxCell id="intake-header" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=17;fontStyle=1;align=center;verticalAlign=middle;" value="&lt;b&gt;IntakeAgent + IntakePrompts&lt;/b&gt;&lt;br&gt;Ветка вызывается, когда flow_phase = intake" vertex="1">
          <mxGeometry height="60" width="1000" x="-840" y="280" as="geometry" />
        </mxCell>
        <mxCell id="intake-system" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;align=left;verticalAlign=top;spacing=8;" value="&lt;b&gt;IntakePrompts.get_system_message()&lt;/b&gt;&lt;br&gt;&lt;br&gt;Назначение: задать persona intake-консультанта и ограничения intake-этапа.&lt;br&gt;&lt;br&gt;Входы:&lt;br&gt;- therapist_name&lt;br&gt;- therapist_gender&lt;br&gt;- therapist_styles&lt;br&gt;&lt;br&gt;Выход:&lt;br&gt;- system prompt для intake LLM" vertex="1">
          <mxGeometry height="230" width="430" x="-270" y="370" as="geometry" />
        </mxCell>
        <mxCell id="intake-turn" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;align=left;verticalAlign=top;spacing=8;" value="&lt;b&gt;IntakePrompts.get_intake_turn_prompt()&lt;/b&gt;&lt;br&gt;&lt;br&gt;Назначение: собрать / обновить clinical card на одном intake-ходе.&lt;br&gt;&lt;br&gt;Входы:&lt;br&gt;- patient_message&lt;br&gt;- patient_name, age, sex&lt;br&gt;- address_mode&lt;br&gt;- current_card&lt;br&gt;- min_user_turns / current_user_turns&lt;br&gt;- required_fields&lt;br&gt;- recent_dialogue&lt;br&gt;- therapist_name / gender / styles&lt;br&gt;&lt;br&gt;Выход:&lt;br&gt;- JSON: mental_history, physical_history, current_problems, intake_hypothesis, explanation, missing_fields, is_intake_complete, patient_response_ru" vertex="1">
          <mxGeometry height="382.5" width="430" x="-270" y="630" as="geometry" />
        </mxCell>
        <mxCell id="intake-fallback" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=light-dark(#fde4e2, #512d2b);strokeColor=#b85450;fontSize=14;align=left;verticalAlign=top;spacing=8;" value="&lt;b&gt;IntakePrompts.get_fallback_intake_response()&lt;/b&gt;&lt;br&gt;&lt;br&gt;Назначение: fallback-вопрос пользователю, если intake LLM не дал валидный результат.&lt;br&gt;&lt;br&gt;Входы:&lt;br&gt;- patient_name&lt;br&gt;- address_mode&lt;br&gt;- therapist_gender&lt;br&gt;&lt;br&gt;Выход:&lt;br&gt;- короткий intake response text" vertex="1">
          <mxGeometry height="235" width="430" x="-270" y="1280" as="geometry" />
        </mxCell>
        <mxCell id="evaluator-header" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=17;fontStyle=1;align=center;verticalAlign=middle;" value="&lt;b&gt;TherapistEvaluator + EvaluatorPrompts&lt;/b&gt;&lt;br&gt;Скрытый аналитический слой, не пишет пользователю напрямую" vertex="1">
          <mxGeometry height="60" width="2640" x="240" y="280" as="geometry" />
        </mxCell>
        <mxCell id="eval-emotion" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=14;align=left;verticalAlign=top;spacing=8;arcSize=6;strokeWidth=2;" value="&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;b style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(237, 237, 237));&quot;&gt;&lt;font&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;EMOTION_ASSESSMENT&lt;/font&gt;&lt;/b&gt;&lt;/div&gt;&lt;font&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;font style=&quot;background-color: transparent; color: rgb(0, 0, 0);&quot;&gt;&lt;font style=&quot;&quot; face=&quot;Helvetica&quot;&gt;&lt;b&gt;Назначение&lt;/b&gt;: &lt;/font&gt;&lt;/font&gt;&lt;span style=&quot;background-color: transparent; color: rgb(230, 237, 243);&quot;&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot; face=&quot;Helvetica&quot;&gt;Определить основную эмоцию пациента и оценить ее интенсивность по текущему сообщению.&amp;nbsp;&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(237, 237, 237)); background-color: transparent;&quot;&gt;Не ограничивается поверхностным эмоциональным тоном, а отдельно требует&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(237, 237, 237));&quot;&gt;учитывать скрытые, замаскированные эмоции.&lt;/span&gt;&lt;/div&gt;&lt;/font&gt;&lt;/font&gt;&lt;div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;font&gt;&lt;font face=&quot;Helvetica&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;font&gt;&lt;font style=&quot;&quot; face=&quot;Helvetica&quot;&gt;&lt;font&gt;&lt;b&gt;Модели назначается инструкция&lt;/b&gt;&lt;/font&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;: профессиональный и эмпатичный&amp;nbsp; психологический консультант, е&lt;/span&gt;&lt;/font&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;й дается задача определить:&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;font face=&quot;Helvetica&quot;&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;- основную эмоцию&lt;/span&gt;&lt;/div&gt;    &lt;span style=&quot;white-space: pre;&quot;&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); white-space: normal;&quot;&gt;-&amp;nbsp; эмоциональная интенсивность&lt;/span&gt;&lt;/div&gt;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); white-space: normal;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); white-space: normal;&quot;&gt;Основную эмоцию разрешено выбирать только из фиксированного списка:&lt;/span&gt;&lt;/div&gt;&lt;/span&gt;&lt;/font&gt;&lt;div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;font&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;- Радость&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;  &lt;font face=&quot;Helvetica&quot;&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;- Грусть&lt;/span&gt;&lt;/div&gt;    &lt;span style=&quot;white-space: pre;&quot;&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); white-space: normal;&quot;&gt;- Злость&lt;/span&gt;&lt;/div&gt;&lt;/span&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;- Страх&lt;/span&gt;&lt;/div&gt;    &lt;span style=&quot;white-space: pre;&quot;&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); white-space: normal;&quot;&gt;- Отвращение&lt;/span&gt;&lt;/div&gt;&lt;/span&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- Удивление&lt;/span&gt;&lt;/div&gt;    &lt;span style=&quot;white-space: pre;&quot;&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); white-space: normal;&quot;&gt;- Доверие&lt;/span&gt;&lt;/div&gt;&lt;/span&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;- Предвкушение/ожидание&lt;/span&gt;&lt;/div&gt;  &lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;font face=&quot;Helvetica&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;font face=&quot;Helvetica&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Инструкция явно говорит, что нужно выбирать &lt;/span&gt;&lt;b style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;одну главную эмоцию&lt;/b&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;, то есть самую интенсивную в сообщении.&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;font face=&quot;Helvetica&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;font&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Отдельно встроено правило на распознавание замаскированных эмоций:&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;font face=&quot;Helvetica&quot;&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- злость может маскировать боль, страх, уязвимость, стыд;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- юмор или шутки могут маскировать тревогу, дискомфорт, боль, страх;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- интеллектуализация может маскировать эмоциональную перегрузку, грусть,&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;страх;&lt;/span&gt;&lt;/div&gt;    &lt;div style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;white-space: normal; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- уход в &lt;/span&gt;&lt;code style=&quot;white-space: normal; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;I don&#39;t know&lt;/code&gt;&lt;span style=&quot;white-space: normal; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt; (я не знаю) может маскировать страх, стыд,&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;white-space: normal; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;беспомощность;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Инструкция требует, чтобы при наличии маскировки модель выбирала не &lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;поверхностную эмоцию, а &lt;/span&gt;&lt;b style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;лежащую под ней эмоцию&lt;/b&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;;&lt;/span&gt;&lt;/div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;font face=&quot;Helvetica&quot; style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); white-space: normal;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;font face=&quot;Helvetica&quot; style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); white-space: normal;&quot;&gt;Дополнительно в инструкции оказано ориентироваться не только на буквальные слова,&amp;nbsp;&lt;/font&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); white-space: normal;&quot;&gt;но и на предполагаемое внутреннее состояние пациента.&lt;/span&gt;&lt;/div&gt;&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;font&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Интенсивность эмоции оценивается как число от &lt;/span&gt;&lt;code style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;0&lt;/code&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt; до &lt;/span&gt;&lt;code style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;1:&lt;/code&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;font&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- &lt;/span&gt;&lt;code style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;0.0–0.3&lt;/code&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt; — слабая / едва заметная;&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;font face=&quot;Helvetica&quot;&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;- &lt;/span&gt;&lt;code style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;0.4–0.6&lt;/code&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt; — умеренная;&lt;/span&gt;&lt;/div&gt;    &lt;span style=&quot;white-space: pre;&quot;&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); white-space: normal;&quot;&gt;- &lt;/span&gt;&lt;code style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); white-space: normal;&quot;&gt;0.7–0.8&lt;/code&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); white-space: normal;&quot;&gt; — высокая;&lt;/span&gt;&lt;/div&gt;&lt;/span&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;- &lt;/span&gt;&lt;code style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;0.9–1.0&lt;/code&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt; — очень высокая, перегружающая или кризисная;&lt;/span&gt;&lt;/div&gt;  &lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;font&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;font face=&quot;Helvetica&quot;&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;b style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Вход:&amp;nbsp;&lt;/b&gt;&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: rgb(255, 153, 255);&quot;&gt;текущее сообщение пациента.&lt;/span&gt;&lt;/div&gt;&lt;b style=&quot;&quot;&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;font face=&quot;Helvetica&quot; style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); font-weight: normal;&quot;&gt;&lt;b&gt;Выход:&amp;nbsp;&lt;/b&gt;&lt;/font&gt;&lt;code style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); font-weight: normal;&quot;&gt;JSON&lt;/code&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); font-weight: normal;&quot;&gt;&amp;nbsp;вида:&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); font-weight: normal;&quot;&gt;&amp;nbsp;{&quot;primary_emotion&quot;: &quot;str&quot;,&quot;emotional_intensity&quot;: &quot;float&quot;}&lt;/span&gt;&lt;/div&gt;&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="690" width="1005" x="240" y="2060" as="geometry" />
        </mxCell>
<mxCell id="eval-end" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=14;align=left;verticalAlign=top;spacing=8;imageHeight=24;arcSize=6;strokeWidth=2;" value="&lt;blockquote style=&quot;margin: 0px 0px 0px 40px; border-width: medium; border-style: none; border-color: currentcolor; border-image: initial; padding: 0px;&quot;&gt;&lt;blockquote style=&quot;margin: 0px 0px 0px 40px; border-width: medium; border-style: none; border-color: currentcolor; border-image: initial; padding: 0px;&quot;&gt;&lt;blockquote style=&quot;margin: 0px 0px 0px 40px; border-width: medium; border-style: none; border-color: currentcolor; border-image: initial; padding: 0px;&quot;&gt;&lt;blockquote style=&quot;margin: 0px 0px 0px 40px; border-width: medium; border-style: none; border-color: currentcolor; border-image: initial; padding: 0px;&quot;&gt;&lt;b style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;code&gt;FAREWELL_INTENT&lt;/code&gt; (Завершение сессии)&lt;/b&gt;&lt;/blockquote&gt;&lt;blockquote style=&quot;margin: 0px 0px 0px 40px; border-width: medium; border-style: none; border-color: currentcolor; border-image: initial; padding: 0px;&quot;&gt;&lt;b style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;br&gt;&lt;/b&gt;&lt;/blockquote&gt;&lt;/blockquote&gt;&lt;/blockquote&gt;&lt;/blockquote&gt;&lt;b&gt;Назначение&lt;/b&gt;: определить, хочет ли пациент завершить текущий разговор.&lt;div&gt;&lt;br&gt;&lt;b&gt;Модели назначается инструкция&lt;/b&gt;: строго оценить текущее сообщение пациента и понять, выражает ли он явное намерение закончить сессию. Модель не должна анализировать общее настроение, усталость или косвенное снижение интереса, а должна реагировать только на прямой сигнал завершения.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Это точка, где агент решает: пора ли действительно завершать сессию, или разговор нужно продолжать. Инструкция явно требует учитывать один главный источник контекста:&lt;br&gt;текущее сообщение пациента. Агент&amp;nbsp;должен опираться только на текущие слова пациента, а не на всю историю диалога или общую динамику сессии.&lt;br&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Фактически модель должна проверить, есть ли в сообщении явное намерение закончить разговор, если такое намерение есть, вернуть истина, если его нет, вернуть ложь.&lt;br&gt;&lt;br&gt;Отдельно вшито ограничение на структуру ответа:&lt;br&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- допустимы только &lt;code&gt;True&lt;/code&gt;&amp;nbsp;или &lt;code&gt;False&lt;/code&gt;&amp;nbsp;;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- никаких пояснений добавлять нельзя.&lt;br&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;Вход&lt;/b&gt;: текущее сообщение пациента.&lt;br&gt;&lt;b&gt;Выход&lt;/b&gt;: &lt;code&gt;Boolean&lt;/code&gt; (булево значение) вида: &lt;code&gt;True&lt;/code&gt; (истина) / &lt;code&gt;False&lt;/code&gt; (ложь).&lt;/div&gt;" vertex="1">
          <mxGeometry height="430" width="630" x="1130" y="1580" as="geometry" />
        </mxCell>
        <mxCell id="eval-memory" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=14;align=left;verticalAlign=top;spacing=8;arcSize=6;strokeWidth=2;" value="&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;b style=&quot;background-color: rgb(255, 153, 153);&quot;&gt;MEMORY_USAGE (использование памяти)&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;Назначение&lt;/b&gt;: определить, нужно ли обращаться к истории прошлых разговоров, чтобы корректно ответить на текущее сообщение пациента.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;Модели назначается инструкция&lt;/b&gt;: проверить, есть ли в истории диалогов фрагменты, которые явно связаны с текущими словами пациента и при этом не слишком далеки от текущего контекста.&amp;nbsp;&amp;nbsp;&lt;/div&gt;&lt;div&gt;Если такие фрагменты есть, нужно вернуть краткое саммари релевантной памяти. Если нет - прямо сказать, что память не нужна.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Фокус промпта ориентирован не на полную суммаризацию всей истории, а на выборочное извлечение памяти.&amp;nbsp;&amp;nbsp;&lt;/div&gt;&lt;div&gt;То есть это точка, где агент решает,&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;нужно ли вообще подтягивать прошлые диалоги,&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;и если нужно, то какие именно сведения кратко передать дальше.&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Инструкция явно требует учитывать два источника контекста:&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- всю историю диалогов;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- текущее сообщение пациента.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Агент должен опираться на связь между текущим сообщением и прошлой историей, а не просто пересказывать прошлые сессии.&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Отдельно вшито ограничение на структуру ответа:&lt;/div&gt;&lt;div&gt;- если память нужна, вернуть краткое резюме не длиннее 500 слов;&lt;/div&gt;&lt;div&gt;- если память не нужна, вернуть строку `No need to consider historical conversation memory` (не нужно учитывать память исторических разговоров);&lt;/div&gt;&lt;div&gt;- ответ должен быть сразу на русском языке;&lt;/div&gt;&lt;div&gt;- никаких дополнительных пояснений добавлять нельзя.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;Вход&lt;/b&gt;: вся история диалогов и текущее сообщение пациента.&amp;nbsp;&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;b&gt;Выход&lt;/b&gt;: строка - либо краткое резюме релевантной памяти, либо `&lt;i&gt;No need to consider historical conversation memory&lt;/i&gt;` (не нужно учитывать память исторических разговоров).&lt;/div&gt;" vertex="1">
          <mxGeometry height="560" width="830" x="245" y="1460" as="geometry" />
        </mxCell>
        <mxCell id="eval-stage" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=14;align=left;verticalAlign=top;spacing=8;strokeWidth=2;arcSize=6;" value="&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;b style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;TREATMENT_STAGE (Стадия лечения)&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;b style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;br&gt;&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;b&gt;Назначение&lt;/b&gt;: определить текущую стадию терапевтического процесса в виде короткого аналитического &lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;саммари.&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;b&gt;Модели назначается инструкция&lt;/b&gt;: К&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;ратко обобщить, что уже было сделано в терапии,&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;показать, на каком этапе сейчас находится работа и&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;указать, куда логично двигаться на следующей встрече.&amp;nbsp;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;С&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;тадия лечения в этом агенте не является &lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;классификационной задачей&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;, просто формирует свободный, но строго ограниченный по объему аналитический абзац.&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Инструкция явно требует учитывать два источника контекста:&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- текущая терапия;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- вся история диалогов.&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Агент не должен рассуждать о стадии лечения в вакууме.&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Она должна:&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- соотнести динамику диалога с текущим терапевтическим подходом.&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- понять, что уже было пройдено;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- извлечь &lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;динамику продвижения из истории общения;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- Сформировать &lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;логику следующего шага на будущую сессию.&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Инструкция просит ответить сразу на три скрытых вопроса:&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- Что уже произошло в терапии;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- Где мы находимся сейчас;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- Что делать дальше.&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Отдельно вшито ограничение на стиль ответа:&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- анализ должен быть &lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;содержательно полным;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- анализ должен &lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;кратким и компактным;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- длина ответа не должна превышать 80 слов.&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;В инструкцию вшито, что агент не должен объяснять свою оценку стадии, а сразу дать итоговую формулировку стадии.&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Фокус ориентирован не просто на ретроспективное &lt;font face=&quot;monospace&quot;&gt;саммари,&amp;nbsp;&lt;/font&gt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;он также требует проложить&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;связность и преемственность в следующую сессию,&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;поэтому &lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;b&gt;стадия лечения&amp;nbsp;&lt;/b&gt;здесь описывает не только прошлое состояние, но и траекторию дальнейшей работы.&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;b&gt;Вход&lt;/b&gt;: история текущей терапии и вся история диалогов.&lt;br&gt;&lt;b&gt;Выход&lt;/b&gt;: строка - короткий связный аналитический абзац о текущей стадии лечения.&lt;/div&gt;" vertex="1">
          <mxGeometry height="738" width="630" x="1130" y="380" as="geometry" />
        </mxCell>
        <mxCell id="eval-progress" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=14;align=left;verticalAlign=top;spacing=8;arcSize=6;strokeWidth=2;" value="&lt;b&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;/span&gt;THERAPY_PROGRESS&amp;nbsp;&lt;/b&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;(&lt;b&gt;Оценка эффекта прошлой сессии&lt;/b&gt;)&lt;/span&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;Назначение&lt;/b&gt;: оценить, сработала ли терапия в прошлой сессии, и решить, нужно ли сохранить ее или сменить на новую.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;Модели назначается инструкция&lt;/b&gt;: определить новую терапию для новой сессии и кратко объяснить свое решение.&amp;nbsp;&amp;nbsp;&lt;/div&gt;&lt;div&gt;Она должна оценить, был ли терапевтический эффект от прошлой сессии с учетом, с учетом полного диалога прошлой сессии.&lt;/div&gt;&lt;div&gt;Фокус инструкции - межсессионная переоценка терапии.&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Если прошлый подход сработал, его нужно сохранить. Если не сработал - сменить.&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Ограничения ответа:&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- можно выбрать одну терапию или комбинацию максимум из двух;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- название терапии должно быть в профессиональной терминологии;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- причина должна быть не длиннее &lt;span style=&quot;background-color: rgb(255, 153, 255);&quot;&gt;50 &lt;/span&gt;слов;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- ответ должен быть строго в формате JSON.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;Вход&lt;/b&gt;: терапия прошлой сессии и полный диалог прошлой сессии.&amp;nbsp;&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;b&gt;Выход&lt;/b&gt;: `JSON` вида: `{&quot;new_therapy&quot;: &quot;str&quot;, &quot;reason&quot;: &quot;str&quot;}`.&lt;/div&gt;" vertex="1">
          <mxGeometry height="340" width="840" x="240" y="1095.5" as="geometry" />
        </mxCell>
        <mxCell id="therapist-header" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=17;fontStyle=1;align=center;verticalAlign=middle;strokeWidth=2;" value="&lt;b&gt;TherapistAgent + TherapistPrompts&lt;/b&gt;&lt;br&gt;Финальная генерация ответа пользователю" vertex="1">
          <mxGeometry height="60" width="1240" x="3000" y="310" as="geometry" />
        </mxCell>
        <mxCell id="therapist-system" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=14;align=left;verticalAlign=top;spacing=8;strokeWidth=2;" value="&lt;b&gt;TherapistPrompts.get_system_message()&lt;/b&gt;&lt;br&gt;&lt;br&gt;Назначение: persona психолога + therapeutic principles + style switching + address mode.&lt;br&gt;&lt;br&gt;Входы:&lt;br&gt;- therapist_name&lt;br&gt;- therapist_gender&lt;br&gt;- therapist_styles&lt;br&gt;- address_mode&lt;br&gt;&lt;br&gt;Выход:&lt;br&gt;- therapist system prompt" vertex="1">
          <mxGeometry height="240" width="360" x="3880" y="390" as="geometry" />
        </mxCell>
        <mxCell id="therapist-response" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=14;align=left;verticalAlign=top;spacing=8;strokeWidth=2;" value="&lt;b&gt;TherapistPrompts.get_response_prompt()&lt;/b&gt;&lt;br&gt;&lt;br&gt;Назначение: собрать полный prompt для финального therapy-response.&lt;br&gt;&lt;br&gt;Входы:&lt;br&gt;- patient_input&lt;br&gt;- memory_result&lt;br&gt;- primary_emotion + intensity&lt;br&gt;- current_therapy&lt;br&gt;- current_stage&lt;br&gt;- strategy + strategy_text&lt;br&gt;- session_memory&lt;br&gt;- user profile + therapist persona&lt;br&gt;&lt;br&gt;Выход:&lt;br&gt;- user prompt для LLM, который должен вернуть финальный ответ &lt;= 60 слов" vertex="1">
          <mxGeometry height="330" width="360" x="3880" y="653.5" as="geometry" />
        </mxCell>
        <mxCell id="therapist-greetings" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=14;align=left;verticalAlign=top;spacing=8;strokeWidth=2;" value="&lt;b&gt;Greeting / fallback templates&lt;/b&gt;&lt;br&gt;&lt;br&gt;- get_first_session_greeting()&lt;br&gt;- get_return_session_greeting()&lt;br&gt;- get_fallback_response()&lt;br&gt;&lt;br&gt;Назначение:&lt;br&gt;- старт первой / повторной сессии&lt;br&gt;- graceful fallback при LLM failure" vertex="1">
          <mxGeometry height="190" width="360" x="3880" y="1005" as="geometry" />
        </mxCell>
        <mxCell id="eval-initial" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=14;align=left;verticalAlign=top;spacing=8;imageHeight=24;arcSize=6;strokeWidth=2;" value="&lt;blockquote style=&quot;margin: 0px 0px 0px 40px; border-width: medium; border-style: none; border-color: currentcolor; border-image: initial; padding: 0px;&quot;&gt;&lt;blockquote style=&quot;margin: 0px 0px 0px 40px; border-width: medium; border-style: none; border-color: currentcolor; border-image: initial; padding: 0px;&quot;&gt;&lt;blockquote style=&quot;margin: 0px 0px 0px 40px; border-width: medium; border-style: none; border-color: currentcolor; border-image: initial; padding: 0px;&quot;&gt;&lt;code style=&quot;&quot;&gt;&lt;span style=&quot;font-weight: bold; white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;font-weight: bold; white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;font-weight: bold; white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;font-weight: bold; white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;font-weight: bold; white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;b&gt;INITIAL_THERAPY&lt;/b&gt;&lt;/code&gt;&lt;b&gt; (Выбор терапии)&lt;/b&gt;&lt;/blockquote&gt;&lt;/blockquote&gt;&lt;/blockquote&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;div&gt;&lt;b&gt;Назначение&lt;/b&gt;: определить &lt;b&gt;начальный &lt;/b&gt;терапевтический подход на основе медицинской записи пациента в виде краткой рекомендации по виду психотерапии.&lt;br&gt;&lt;br&gt;&lt;b&gt;Модели назначается инструкция&lt;/b&gt;: рекомендовать подходящую психологическую терапию на основе медицинской записи пациента.  &lt;br&gt;Она должна не анализировать состояние в свободной форме, а выбрать конкретный терапевтический подход, который лучше всего подходит под собранный клинический материал.&lt;/div&gt;&lt;div&gt;&lt;br&gt;Фокус промпта ориентирован на то, чтобы перевести уже собранную клиническую информацию в стартовую терапевтическую рамку.&lt;br&gt;То есть это точка, где данные из первичного обследования превращаются в практическое решение: в каком подходе дальше вести работу.&lt;/div&gt;&lt;div&gt;&lt;br&gt;Инструкция явно требует учитывать один главный источник контекста:&lt;br&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- медицинскую запись пациента.&lt;br&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;То есть агент должен опираться на уже собранную клиническую информацию о пациенте, а не на текущее сообщение или текущую сессию отдельно.  &lt;br&gt;Фактически модель должна:&lt;br&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- извлечь из медицинской записи основные психологические и клинические признаки;&lt;br&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- соотнести их с подходящими психотерапевтическими подходами;&lt;br&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- выбрать один наиболее подходящий вариант или разумную комбинацию;&lt;br&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- вернуть итог в виде профессионального названия терапии.&lt;br&gt;&lt;br&gt;Инструкция просит ответить на один главный скрытый вопрос:&lt;br&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- какой терапевтический подход лучше всего подойдет этому пациенту на старте работы.&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Отдельно вшито ограничение на структуру ответа:&lt;br&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- можно выбрать одну терапию;&lt;br&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- можно выбрать комбинацию терапий;&lt;br&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- если выбирается комбинация, то не более двух терапий;&lt;br&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- ответ должен содержать только профессиональное название терапии.&lt;br&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;b&gt;Вход&lt;/b&gt;: медицинская запись пациента.  &lt;br&gt;&lt;b&gt;Выход&lt;/b&gt;: строка - профессиональное название одной терапии или комбинации из двух терапий, без пояснений.&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="699" width="840" x="240" y="372" as="geometry" />
        </mxCell>
        <mxCell id="9RzXrqQqmixDVCmXII7v-8" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=14;align=left;verticalAlign=top;spacing=8;arcSize=6;strokeWidth=2;" value="&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;b&gt;THERAPIST_AGENT (финальный ответ терапевта)&lt;/b&gt;&amp;nbsp;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;Назначение&lt;/b&gt;: сформировать &lt;b&gt;готовую финальную реплику пациенту&lt;/b&gt;&amp;nbsp;на основе всех промежуточных аналитических решений, которые до этого подготовил терапевт-оценщик.&lt;br&gt;&lt;br&gt;Это уже генеративный слой. Его задача построить &lt;b&gt;что именно сказать пациенту&lt;/b&gt;.&lt;br&gt;&lt;br&gt;&lt;br&gt;Модели назначается инструкция: опытный и эмпатичный психологический консультант, который должен отвечать пациенту профессионально, поддерживающе, естественно и в рамках терапевтических границ.&lt;br&gt;&lt;br&gt;В системную инструкцию встроены базовые принципы, которые нарушать нельзя:&lt;br&gt;- `neutrality` (нейтральность) - не навязывать пациенту свои ценности, мораль, политические взгляды, не оценивать его как «правильного» или «неправильного»;&lt;br&gt;- `boundaries` (границы) - не быть другом, спасателем, родителем или коучем, не давать прямых советов и не обещать, что «все будет хорошо»;&lt;br&gt;- `non-directive stance` (недирективная позиция) - не тащить пациента силой в тему, не давить, не торопить, давать пациенту вести разговор;&lt;br&gt;- `empathic reflection` (эмпатическое отражение) - признавать и удерживать чувства пациента, а не сразу чинить, утешать или исправлять;&lt;br&gt;- `unconditional positive regard` (безоценочное принятие) - принимать переживания и мысли пациента без морализаторства;&lt;br&gt;- `client-centered focus` (клиент-центрированный фокус) - опираться на субъективный опыт пациента, а не на внешние «объективные» стандарты.&lt;br&gt;&lt;br&gt;То есть системный слой жестко ограничивает модель:&lt;br&gt;- нельзя становиться директивной;&lt;br&gt;- нельзя лечить советами;&lt;br&gt;- нельзя давать ложные гарантии;&lt;br&gt;- нельзя уходить в токсичный позитив;&lt;br&gt;- нельзя ставить себя в центр разговора.&lt;br&gt;&lt;br&gt;Отдельно в системный промпт вшита персонализация терапевта:&lt;br&gt;- имя терапевта;&lt;br&gt;- пол терапевта;&lt;br&gt;- набор выбранных стилей общения;&lt;br&gt;- формат обращения к пациенту: `formal` (формальный, на «вы») или `informal` (неформальный, на «ты»).&lt;br&gt;&lt;br&gt;Если у терапевта включены стили общения, системный слой задает один или несколько доступных стилей:&lt;br&gt;- `friendly` (дружелюбный) - теплый, открытый, для контакта и нейтральных тем;&lt;br&gt;- `soft` (мягкий) - спокойный, очень бережный, для тревоги, боли, перегрузки;&lt;br&gt;- `business` (структурированный) - ясный, собранный, для исследования паттернов, симптомов и фактов;&lt;br&gt;- `motivating` (поддерживающий, мотивирующий) - с акцентом на ресурсы, изменения и цели.&lt;br&gt;&lt;br&gt;Для каждого стиля в системный промпт встроены не только языковые маркеры, но и `boundary checks` (проверки границ), то есть специальные запреты:&lt;br&gt;- для `friendly` (дружелюбного) - не скатываться в дружбу, не уходить в юмор как защиту, не говорить «я тебя понимаю»;&lt;br&gt;- для `soft` (мягкого) - не обещать, что все будет хорошо, не брать на себя ответственность за чувства пациента, не говорить «не переживай»;&lt;br&gt;- для `business` (структурированного) - не превращаться в холодного интервьюера, не ставить диагнозы, не давать инструкций;&lt;br&gt;- для `motivating` (поддерживающего) - не навязывать цели, не давить позитивом, не присваивать прогресс пациента.&lt;br&gt;&lt;br&gt;То есть важная скрытая логика финального промпта в том, что он контролирует не только *содержание* ответа, но и *манеру*, *границы* и *этическую рамку* ответа.&lt;br&gt;&lt;br&gt;После системного слоя идет `get_response_prompt()` (промпт ответа).  &lt;br&gt;Именно он передает модели весь актуальный контекст конкретного хода.&lt;br&gt;&lt;br&gt;Инструкция в пользовательской части промпта говорит модели:&lt;br&gt;- ответить пациенту сочувственно и профессионально;&lt;br&gt;- опереться на текущий и исторический контекст;&lt;br&gt;- встроить в ответ текущую терапевтическую стратегию;&lt;br&gt;- сделать ответ естественным, разговорным и не шаблонным;&lt;br&gt;- не писать анализ, а сразу дать готовую реплику.&lt;br&gt;&lt;br&gt;На вход финальному промпту передаются:&lt;br&gt;&lt;br&gt;- `patient_input` (текущее сообщение пациента);&lt;br&gt;- `memory_result` (релевантная память из прошлых диалогов или вывод, что память не нужна);&lt;br&gt;- `primary_emotion` (основная эмоция пациента);&lt;br&gt;- `emotional_intensity` (интенсивность эмоции);&lt;br&gt;- `current_therapy` (текущая терапия);&lt;br&gt;- `current_stage` (текущая стадия лечения);&lt;br&gt;- `current_strategy` (выбранная стратегия ответа);&lt;br&gt;- `current_strategy_text` (краткая инструкция, как отвечать в рамках стратегии);&lt;br&gt;- `session_memory` (недавняя история текущей сессии, чтобы не повторять один и тот же шаблон ответа);&lt;br&gt;- имя терапевта;&lt;br&gt;- имя пациента;&lt;br&gt;- возраст пациента;&lt;br&gt;- пол пациента;&lt;br&gt;- доступные стили общения;&lt;br&gt;- режим обращения: на «вы» или на «ты».&lt;br&gt;&lt;br&gt;То есть по факту `TherapistAgent` (терапевтический агент) получает уже не сырые сообщения, а собранный контекст из нескольких слоев:&lt;br&gt;- что чувствует пациент;&lt;br&gt;- насколько сильно;&lt;br&gt;- нужна ли память;&lt;br&gt;- на какой стадии терапия;&lt;br&gt;- какая стратегия ответа выбрана;&lt;br&gt;- в каком стиле нужно говорить;&lt;br&gt;- как именно обращаться к пациенту.&lt;br&gt;&lt;br&gt;Финальная инструкция требует от модели соблюдать несколько очень важных правил ответа:&lt;br&gt;&lt;br&gt;- отвечать максимально естественно и разговорно;&lt;br&gt;- не повторять механически слова пациента;&lt;br&gt;- эмпатизировать кратко и по делу;&lt;br&gt;- использовать разные синтаксические конструкции, чтобы ответы не были однообразными;&lt;br&gt;- ориентироваться на предыдущие реплики текущей сессии, чтобы не дублировать один и тот же шаблон;&lt;br&gt;- если пациент явно хочет завершить разговор, дать завершающий ответ;&lt;br&gt;- обязательно воплотить `ACTIVE STYLE` (активный стиль), если он определен;&lt;br&gt;- отвечать строго на том же языке, что и пациент;&lt;br&gt;- не превышать 60 слов;&lt;br&gt;- не писать анализ, пояснение, комментарий о стратегии или количество слов;&lt;br&gt;- сразу выводить только готовый ответ пациенту.&lt;br&gt;&lt;br&gt;Отдельно в промпте есть скрытая логика выбора `ACTIVE STYLE` (активного стиля).  &lt;br&gt;Если у терапевта доступно несколько стилей, промпт пытается подсказать, какой стиль сделать активным в текущем ходе:&lt;br&gt;- при сильной негативной эмоции приоритет у `soft` (мягкого);&lt;br&gt;- при более структурной, рациональной работе - у `business` (структурированного);&lt;br&gt;- при теме целей, изменений, ресурсов - у `motivating` (поддерживающего);&lt;br&gt;- при нейтральном контакте и раппорте - у `friendly` (дружелюбного).&lt;br&gt;&lt;br&gt;Это означает, что финальный ответ строится не просто как текст, а как текст, который должен:&lt;br&gt;- соответствовать эмоциональному состоянию пациента;&lt;br&gt;- соответствовать терапевтической стратегии;&lt;br&gt;- соответствовать стилю конкретного терапевта;&lt;br&gt;- соответствовать режиму обращения;&lt;br&gt;- соответствовать языку пациента;&lt;br&gt;- соответствовать ограничениям терапевтической этики.&lt;br&gt;&lt;br&gt;По сути финальный промпт заставляет модель одновременно удерживать несколько осей:&lt;br&gt;- клиническую уместность;&lt;br&gt;- эмоциональную уместность;&lt;br&gt;- стилистическую согласованность;&lt;br&gt;- терапевтические границы;&lt;br&gt;- языковую точность;&lt;br&gt;- краткость ответа.&lt;br&gt;&lt;br&gt;Важнейший скрытый смысл этого промпта:  &lt;br&gt;он превращает результаты evaluator-слоя в уже практически готовую «матрицу ответа».  &lt;br&gt;То есть основная модель не решает все с нуля. Ей уже передали:&lt;br&gt;- что происходит;&lt;br&gt;- как это понимать;&lt;br&gt;- какой терапевтический режим нужен;&lt;br&gt;- каков контекст терапии;&lt;br&gt;- каков контекст прошлых сообщений;&lt;br&gt;- каким тоном говорить;&lt;br&gt;- какие границы нельзя нарушать.&lt;br&gt;&lt;br&gt;Из-за этого финальный `TherapistAgent` (терапевтический агент) работает не как свободный чат-бот, а как сильно ограниченный и направляемый генератор терапевтической реплики.&lt;br&gt;&lt;br&gt;Вход:  &lt;br&gt;текущее сообщение пациента, релевантная память, основная эмоция, интенсивность эмоции, текущая терапия, стадия лечения, стратегия ответа, инструкция стратегии, недавняя история сессии и персонализация терапевта/пациента.&lt;br&gt;&lt;br&gt;Выход:  &lt;br&gt;строка - финальная терапевтическая реплика пациенту, естественная, эмпатичная, в нужном стиле, на языке пациента, без анализа и пояснений, длиной не более 60 слов.&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="2642.5" width="830" x="3000" y="397.5" as="geometry" />
        </mxCell>
        <mxCell id="9RzXrqQqmixDVCmXII7v-9" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=14;align=left;verticalAlign=top;spacing=8;arcSize=6;strokeWidth=2;" value="&lt;blockquote style=&quot;margin: 0px 0px 0px 40px; border-width: medium; border-style: none; border-color: currentcolor; border-image: initial; padding: 0px;&quot;&gt;&lt;blockquote style=&quot;margin: 0px 0px 0px 40px; border-width: medium; border-style: none; border-color: currentcolor; border-image: initial; padding: 0px;&quot;&gt;&lt;blockquote style=&quot;margin: 0px 0px 0px 40px; border-width: medium; border-style: none; border-color: currentcolor; border-image: initial; padding: 0px;&quot;&gt;&lt;blockquote style=&quot;margin: 0px 0px 0px 40px; border-width: medium; border-style: none; border-color: currentcolor; border-image: initial; padding: 0px;&quot;&gt;&lt;blockquote style=&quot;margin: 0px 0px 0px 40px; border-width: medium; border-style: none; border-color: currentcolor; border-image: initial; padding: 0px;&quot;&gt;&lt;blockquote style=&quot;margin: 0px 0px 0px 40px; border-width: medium; border-style: none; border-color: currentcolor; border-image: initial; padding: 0px;&quot;&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;b&gt;TherapistEvaluator (терапевт-оценщик)&lt;/b&gt;&lt;/div&gt;&lt;/blockquote&gt;&lt;/blockquote&gt;&lt;/blockquote&gt;&lt;/blockquote&gt;&lt;/blockquote&gt;&lt;/blockquote&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;Внутренний аналитический слой системы, который &lt;b&gt;не разговаривает с пациентом напрямую&lt;/b&gt;, а подготавливает&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;финальный ответ.&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Когда отработали &lt;b&gt;EMOTION_ASSESSMENT&lt;/b&gt;, &lt;b&gt;MEMORY_USAGE&lt;/b&gt;, &lt;b&gt;TREATMENT_STAGE&lt;/b&gt;, &lt;b&gt;FAREWELL_INTENT&lt;/b&gt;,&amp;nbsp;&lt;/div&gt;&lt;div&gt;система получает набор уже готовых промежуточных решений:&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Финальная инструкция фактически состоит из двух частей:&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- системное сообщение - кто такая модель, какие у нее границы и принципы;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- инструкция ответа - что происходит прямо сейчас и как нужно ответить в этом конкретном ходе.&lt;/div&gt;&lt;div&gt;Это важно, потому что система разделяет&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;b&gt;постоянную роль &lt;/b&gt;терапевта и&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;ситуационную задачу &lt;b&gt;текущего ответа&lt;/b&gt;.&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Главная задача финальной инструкции:&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- сохранить терапевтическую рамку;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- встроить результат evaluator-аналитики;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- учесть текущую стадию работы;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- учесть персонализацию терапевта;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- учесть стиль общения;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- учесть режим обращения;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- учесть язык пациента;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- не дать модели уйти в советы, морализаторство или пустое утешение;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;-&amp;nbsp;и при этом получить естественный, живой, короткий ответ.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;К моменту генерации ответа у терапевтического агента уже есть несколько слоев входных данных:&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;1. Текущее сообщение пациента&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Это главный триггер текущего хода. Именно на него надо ответить.&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;2. Результат памяти.&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Не вся история в сыром виде, а уже отфильтрованный результат `MEMORY_USAGE` (использования памяти)&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;.&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;3. Эмоциональный профиль текущего сообщения&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Сюда входят:&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;основная эмоция;&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;интенсивность эмоции.&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;4. Терапевтический контекст&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Сюда входят:&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;текущая терапия;&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;текущая стадия лечения.&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;5. Стратегия ответа&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Сюда входят:&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;название выбранной стратегии;&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;краткая инструкция по ней&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;6. Память текущей сессии (&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;чтобы&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;не повторяться,&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;не отвечать все время одной и той же конструкцией и&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;сохранять связность локального диалога).&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;7. Персонализация (&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;имя терапевта,&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;пол терапевта,&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;имя пациента,&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;возраст,&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;пол пациента,&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;стиль обращения:,&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;список доступных стилей общения терапевта).&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;Что делает системная часть промпта&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Системный слой задает &lt;b&gt;роль и границы&lt;/b&gt;.&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;По смыслу он говорит модели примерно следующее:&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- ты профессиональный, эмпатичный психологический консультант;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- ты должен оставаться в терапевтической позиции;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- ты не друг, не спасатель, не коуч и не наставник;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- ты не даешь прямых инструкций;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- ты не навязываешь ценности;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- ты не обещаешь результата;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- ты сохраняешь уважение, принятие и профессиональную дистанцию.&lt;/div&gt;&lt;div&gt;Основные зашитые установки:&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;Нейтральность&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;:&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;- нельзя ценивать пациента;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;/span&gt;- нельзя морально осуждать;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;/span&gt;- нельзя навязывать свои нормы;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;/span&gt;- нельзя делить выборы пациента на &quot;правильные&quot; и &quot;неправильные&quot;.&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;Границы&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;/span&gt;- нельзя становиться слишком личной;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;/span&gt;- нельзя брать на себя роль спасателя;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;/span&gt;- нельзя пытаться &quot;решить жизнь пациента&quot;;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;/span&gt;- нельзя обещать, что все обязательно будет хорошо.&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;Недирективность:&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;/span&gt;- надо задавать открытые вопросы, НО не давить;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;/span&gt;- не форсировать тему;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;/span&gt;- не *тащить* пациента туда, куда он не готов идти.&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;Эмпатическое отражение&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;/span&gt;- признание эмоций;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;/span&gt;- не спешить исправлять;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;/span&gt;- не минимизировать боль;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;/span&gt;- не уходить в токсичный позитив.&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;Безоценочное принятие:&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- принятие пациента как личности;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- отсутствие осуждения;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- пространство без морализаторства.&lt;/div&gt;&lt;div&gt;&lt;span&gt;&lt;span style=&quot;background-color: light-dark(#ffffff, var(--ge-dark-color, #121212)); white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;background-color: light-dark(#ffffff, var(--ge-dark-color, #121212));&quot;&gt;Клиент-центрированный фокус:&lt;/span&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: light-dark(#ffffff, var(--ge-dark-color, #121212));&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;/span&gt;-&amp;nbsp; опираться на внутренний опыт пациента;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: light-dark(#ffffff, var(--ge-dark-color, #121212));&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- на его темп;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: light-dark(#ffffff, var(--ge-dark-color, #121212));&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- на его субъективную реальность.&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;После системного слоя идет основная инструкция &lt;b&gt;текущего хода&lt;/b&gt;.&lt;/div&gt;&lt;div&gt;Она сообщает модели:&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- вот текущее сообщение пациента;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- вот релевантная память;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- вот эмоция и ее сила;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- вот текущая терапия;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- вот стадия лечения;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- вот стратегия ответа;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- вот краткая инструкция по стратегии;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- вот кусок недавней сессии;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- теперь сформулируй терапевтический ответ.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Этот промпт работает&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp;как режим управляемой генерации, чем как свободная беседа.&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Финальный ответ должен быть:&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- естественным;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- разговорным;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- коротким;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- сочувственным;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- не повторяющим дословно сообщение пациента;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- не однообразным по синтаксису;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- соответствующим активному стилю;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- соответствующим выбранной стратегии;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- строго на языке пациента;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- без анализа и служебных комментариев;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- длиной не более &lt;span style=&quot;background-color: rgb(255, 153, 255);&quot;&gt;60&lt;/span&gt; слов.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="1788" width="1070" x="1810" y="390" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
