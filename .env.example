################################################################################
# Opora Configuration
# Copy this file to .env and fill in your values
################################################################################

############################
# [APP] Application Settings
############################
APP_ENV=development
APP_DEBUG=true

############################
# [LOG] Logging Configuration
############################
LOG_LEVEL=INFO
LOG_FILE_ENABLED=true
LOG_FILE_PATH=logs/app.log
LOG_FILE_BACKUP_COUNT=7

############################
# [DB] PostgreSQL Database
############################
# Локальный PostgreSQL (порт и учётные данные — под вашу установку)
DATABASE_URL=postgresql+asyncpg://opora:opora@127.0.0.1:5437/OporaAssistant

############################
# [TELEGRAM] Bot Configuration
############################
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_DROP_PENDING_ON_START=true

############################
# [OPENROUTER] LLM Provider
############################
OPENROUTER_API_KEY=your_openrouter_key_here

############################
# [LLM] Public Model Config
############################
# Публичные и некритичные настройки моделей/гиперпараметров хранятся отдельно.
# Меняйте модели, temperature, max_tokens, top_p и penalties в config/llm_models.json.
LLM_CONFIG_PATH=config/llm_models.json

############################
# [INTAKE] Initial Clinical Intake
############################

# Включение/отключение этапа intake (сбора первичной информации)
INTAKE_ENABLED=true

# Минимальное количество сообщений пользователя перед завершением intake
INTAKE_MIN_USER_TURNS=6

# Поля, обязательные для заполнения в клинической карточке (через запятую)
INTAKE_REQUIRED_FIELDS=current_problems,mental_health_history,physical_health_history

# Множитель для вычисления максимального количества ходов intake
# Формула: INTAKE_MAX_USER_TURNS = INTAKE_MIN_USER_TURNS * INTAKE_MAX_USER_TURNS_MULTIPLIER
# При достижении этого лимита intake завершится, даже если не все данные собраны
INTAKE_MAX_USER_TURNS_MULTIPLIER=2

# Множитель для размера контекстного окна диалога
# Формула: CONTEXT_WINDOW_SIZE = INTAKE_MIN_USER_TURNS * INTAKE_CONTEXT_WINDOW_MULTIPLIER * 2
# (×2 потому что учитываются и сообщения пользователя, и ответы агента)
# Это количество последних реплик, которые видит intake-агент при формировании ответа
INTAKE_CONTEXT_WINDOW_MULTIPLIER=2

# Минимум предложений в patient_response_ru (подсказка в turn directive)
INTAKE_MIN_RESPONSE_SENTENCES=3

# Макс. слов в одном вопросе (если allow_question=true)
INTAKE_MAX_QUESTION_WORDS=25

# Макс. слов в итоговом summary intake
INTAKE_SUMMARY_MAX_WORDS=180

# Порог emotional_intensity для defer БЕЗ вопроса: только кризис (negative emotion + >= 0.95).
# Обычная эмоциональность на intake не отменяет вопросы — см. turn_directives / intake prompts.
INTAKE_HOLD_EMOTION_INTENSITY_THRESHOLD=0.95

