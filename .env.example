################################################################################
# Opora Configuration
# Copy this file to .env and fill in your values
################################################################################

############################
# [APP] Application Settings
############################
APP_ENV=development
APP_DEBUG=true

############################
# [LOG] Logging Configuration
############################
LOG_LEVEL=INFO
LOG_FILE_ENABLED=true
LOG_FILE_PATH=logs/app.log
LOG_FILE_BACKUP_COUNT=7

############################
# [DB] PostgreSQL Database
############################
DATABASE_URL=postgresql+asyncpg://opora:opora@127.0.0.1:5437/OporaAssistant

# Docker Compose PostgreSQL settings (используются в docker-compose.yml)
POSTGRES_DB=OporaAssistant
POSTGRES_USER=opora
POSTGRES_PASSWORD=opora
POSTGRES_PORT=5437

############################
# [TELEGRAM] Bot Configuration
############################
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_DROP_PENDING_ON_START=true

############################
# [OPENROUTER] LLM Provider
############################
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=http://localhost
OPENROUTER_APP_TITLE=Opora

############################
# [LLM] Global Settings
############################
LLM_TIMEOUT_SECONDS=120
LLM_MAX_RETRIES=2

############################
# [LLM] Agent-Specific Settings
############################

# Терапевт-агент (основное терапевтическое взаимодействие)
LLM_THERAPIST_MODEL=Pro/deepseek-ai/DeepSeek-V3
LLM_THERAPIST_TEMPERATURE=0.7
LLM_THERAPIST_MAX_TOKENS=150

# Оценщик (эвалуатор) - для анализа состояния пациента
LLM_EVALUATOR_MODEL=Pro/deepseek-ai/DeepSeek-V3
LLM_EVALUATOR_TEMPERATURE=0.3
LLM_EVALUATOR_MAX_TOKENS=200

# Intake-агент - см. секцию [INTAKE LLM] ниже для расширенных настроек

############################
# [INTAKE] Initial Clinical Intake
############################

# Включение/отключение этапа intake (сбора первичной информации)
INTAKE_ENABLED=true

# Минимальное количество сообщений пользователя перед завершением intake
INTAKE_MIN_USER_TURNS=6

# Поля, обязательные для заполнения в клинической карточке (через запятую)
INTAKE_REQUIRED_FIELDS=current_problems,mental_health_history,physical_health_history

# Множитель для вычисления максимального количества ходов intake
# Формула: INTAKE_MAX_USER_TURNS = INTAKE_MIN_USER_TURNS * INTAKE_MAX_USER_TURNS_MULTIPLIER
# При достижении этого лимита intake завершится, даже если не все данные собраны
INTAKE_MAX_USER_TURNS_MULTIPLIER=2

# Множитель для размера контекстного окна диалога
# Формула: CONTEXT_WINDOW_SIZE = INTAKE_MIN_USER_TURNS * INTAKE_CONTEXT_WINDOW_MULTIPLIER * 2
# (×2 потому что учитываются и сообщения пользователя, и ответы агента)
# Это количество последних реплик, которые видит intake-агент при формировании ответа
INTAKE_CONTEXT_WINDOW_MULTIPLIER=2

############################
# [INTAKE LLM] Гиперпараметры модели для intake-агента
############################

# Модель LLM для intake (сбор первичной информации)
# Рекомендуется использовать ту же модель, что и для терапевта
LLM_INTAKE_MODEL=Pro/deepseek-ai/DeepSeek-V3

# Temperature (0.0 - 1.0+): контролирует креативность/случайность ответов
# Для intake рекомендуется 0.35-0.55:
# - 0.2-0.3: слишком шаблонные, монотонные ответы
# - 0.35-0.5: оптимально - естественная речь с контролем
# - 0.6+: может быть слишком непредсказуемо для клинического контекста
LLM_INTAKE_TEMPERATURE=0.45

# Максимальное количество токенов в ответе (1 токен ≈ 0.75 слова)
# 550 токенов ≈ 400-450 слов
# Достаточно для адаптивных ответов: 2-5 предложений для фактов, 4-7 для эмоций
LLM_INTAKE_MAX_TOKENS=550

# Top-p (0.0 - 1.0): nucleus sampling, альтернатива temperature
# 0.95 означает: используем токены, суммарная вероятность которых = 95%
# 1.0 = отключено, 0.1 = только самые вероятные токены
# Рекомендуется 0.90-0.98 для баланса качества и вариативности
LLM_INTAKE_TOP_P=0.95

# Frequency Penalty (-2.0 - 2.0): штраф за повторение одних и тех же токенов
# Положительные значения снижают вероятность повторов слов/фраз
# 0.0 = без штрафа, 0.3-0.5 = заметное снижение повторов
# Рекомендуется 0.2-0.6 для предотвращения шаблонных фраз
LLM_INTAKE_FREQUENCY_PENALTY=0.3

# Presence Penalty (-2.0 - 2.0): штраф за повторение тем, уже упомянутых в тексте
# Отличается от frequency: penalty применяется один раз за присутствие темы, не за частоту
# 0.0 = без штрафа, 0.1-0.3 = легкое стимулирование новых тем
# Рекомендуется 0.1-0.4 для разнообразия вопросов
LLM_INTAKE_PRESENCE_PENALTY=0.15

############################
# [LANGFUSE] Observability (подключается к внешнему инстансу)
############################
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=your_public_key_here
LANGFUSE_SECRET_KEY=your_secret_key_here
LANGFUSE_BASE_URL=http://localhost:3000
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_GENERATION_DEBUG=false
