################################################################################
# Opora Configuration
# Copy this file to .env and fill in your values
################################################################################

############################
# [APP] Application Settings
############################
APP_ENV=development
APP_DEBUG=true

############################
# [LOG] Logging Configuration
############################
LOG_LEVEL=INFO
LOG_FILE_ENABLED=true
LOG_FILE_PATH=logs/app.log
LOG_FILE_BACKUP_COUNT=7

############################
# [DB] PostgreSQL Database
############################
DATABASE_URL=postgresql+asyncpg://opora:opora@localhost:5437/OporaAssistant

# Docker Compose PostgreSQL settings (используются в docker-compose.yml)
POSTGRES_DB=OporaAssistant
POSTGRES_USER=opora
POSTGRES_PASSWORD=opora
POSTGRES_PORT=5437

############################
# [TELEGRAM] Bot Configuration
############################
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_DROP_PENDING_ON_START=true

############################
# [OPENROUTER] LLM Provider
############################
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=http://localhost
OPENROUTER_APP_TITLE=Opora

############################
# [LLM] Global Settings
############################
LLM_TIMEOUT_SECONDS=120
LLM_MAX_RETRIES=2

############################
# [LLM] Agent-Specific Settings
############################
LLM_THERAPIST_MODEL=Pro/deepseek-ai/DeepSeek-V3
LLM_THERAPIST_TEMPERATURE=0.7
LLM_THERAPIST_MAX_TOKENS=150

LLM_EVALUATOR_MODEL=Pro/deepseek-ai/DeepSeek-V3
LLM_EVALUATOR_TEMPERATURE=0.3
LLM_EVALUATOR_MAX_TOKENS=200

LLM_INTAKE_MODEL=Pro/deepseek-ai/DeepSeek-V3
LLM_INTAKE_TEMPERATURE=0.2
LLM_INTAKE_MAX_TOKENS=350

############################
# [INTAKE] Initial Clinical Intake
############################
INTAKE_ENABLED=true
INTAKE_MIN_USER_TURNS=6
INTAKE_REQUIRED_FIELDS=current_problems,mental_health_history,physical_health_history
INTAKE_MAX_QUESTION_WORDS=35
INTAKE_SUMMARY_MAX_WORDS=180
INTAKE_BACKGROUND_UPDATE_ENABLED=true
INTAKE_BACKGROUND_UPDATE_EVERY_USER_TURNS=4

############################
# [LANGFUSE] Observability (подключается к внешнему инстансу)
############################
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=your_public_key_here
LANGFUSE_SECRET_KEY=your_secret_key_here
LANGFUSE_BASE_URL=http://localhost:3000
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_GENERATION_DEBUG=false
